<%= link_to nil, class: 'dropdown-toggle', :data => { :toggle => 'dropdown' } do %>
  My Forever
  <i class='fa fa-chevron-down'></i>
<% end %>

<div class='dropdown-menu dropdown-menu-nav color_block-gray-700'>
  <div class='container'>
    <div class='row'>
      <div class='col-sm-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-primary-light'>Product Tour</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'Organize Photos in Your Forever Library' do %>
              <i class='fa fa-th-large'></i>Library
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'Create Print Projects' do %>
              <i class='fa fa-paint-brush'></i>Projects
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'Share Photos with Friends and Family' do %>
              <i class='fa fa-users'></i>People
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'View Your Shared Photo Albums' do %>
              <i class='fa fa-home'></i>Home
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'Sign up for Forever' do %>
              <i class='fa fa-user'></i>Sign Up Free!
            <% end %>
          </li>

        </ul>
      </div>

      <div class='col-sm-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-secondary-light'>About</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to 'About Us', nil, class: 'dropdown-menu-nav-link', title: 'About Forever' %>
          </li>

          <li>
            <%= link_to 'Our Team', nil, class: 'dropdown-menu-nav-link', title: 'Meet the Forever Team' %>
          </li>

          <li>
            <%= link_to 'Our Beliefs', nil, class: 'dropdown-menu-nav-link', title: 'Forever Beliefs and Values' %>
          </li>

          <li>
            <%= link_to 'The Forever Guarantee', nil, class: 'dropdown-menu-nav-link', title: 'Forever Guarantee' %>
          </li>

          <li>
            <%= link_to 'Careers', nil, class: 'dropdown-menu-nav-link', title: 'Careers at Forever' %>
          </li>
        </ul>
      </div>

      <div class='col-sm-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-services-light'>Get Started</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'View the Forever Overview Video' do %>
              <i class='fa fa-video-camera'></i>Forever Overview
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'View the Uploading Photos Tutorial Video' do %>
              <i class='fa fa-video-camera'></i>Uploading Photos
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'View the Organizing Photos Tutorial Video' do %>
              <i class='fa fa-video-camera'></i>Getting Organized
            <% end %>
          </li>

          <li>
            <%= link_to nil, class: 'dropdown-menu-nav-link', title: 'View the Sharing Photos Tutorial Video' do %>
              <i class='fa fa-video-camera'></i>Sharing
            <% end %>
          </li>

        </ul>
      </div>

    </div>
  </div>
</div>
