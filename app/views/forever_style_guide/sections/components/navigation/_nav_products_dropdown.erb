<%= link_to nil, class: "dropdown-toggle dropdown-toggle-products #{'active' if is_in_product_dropdown?}", :data => { :toggle => 'dropdown' } do %>
  Products
  <i class='fa fa-chevron-down'></i>
<% end %>

<div class='dropdown-menu dropdown-menu-nav color_block-gray-700'>
  <div class='container dropdown-menu-nav-container'>
    <div class='row'>

      <div class='col-grid-float-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-secondary'>Products</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to 'Photo Books', photo_books_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Photo Books Online or with Artisan Scrapbooking Software' %>
          </li>

          <li>
            <%= link_to 'Cards', cards_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Cards Online or with Artisan Scrapbooking Software' %>
          </li>

          <li>
            <%= link_to 'Calendars', calendars_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Calendars Online or with Artisan Scrapbooking Software' %>
          </li>

          <li>
            <%= link_to 'Wall Art', wall_art_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Canvases Online or with Artisan Scrapbooking Software' %>
          </li>

          <li>
            <%= link_to 'Photo Gifts', photo_gifts_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Photo Gifts Online or with Artisan Scrapbooking Software' %>
          </li>

          <li>
            <%= link_to 'Page Prints', page_prints_url, class: 'dropdown-menu-nav-link', title: 'Create and Print Scrapbooking Pages Online or with Artisan Scrapbooking Software' %>
          </li>
        </ul>
      </div>

      <div class='col-grid-float-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-services'>Design</h3>

        <ul class="list-unstyled">

          <li>
            <%= link_to trademark('Forever Artisan'), artisan_url, class: 'dropdown-menu-nav-link', title: 'Forever Artisan 5 Digital Scrapbooking Software' %>
              <small class="dropdown-menu-nav-link-subhead">Windows Scrapbooking Software</small>
          </li>

          <li>
            <%= link_to trademark('Forever Historian'), historian_url, class: 'dropdown-menu-nav-link', title: 'Photo Management Software for Windows' %>
              <small class="dropdown-menu-nav-link-subhead">Windows Photo Software</small>
          </li>

          <li>
            <%= link_to 'Digital Art', digital_art_url, class: 'dropdown-menu-nav-link', title: 'Premium Digital Scrapbooking Art' %>
            <small class="dropdown-menu-nav-link-subhead hide">Art Kits and Templates for Artisan</small>

            <ul class="dropdown-menu-nav-bullets color-gray-200">
              <li>
                <%= link_to 'New Digital Art', new_digital_art_url, class: 'dropdown-menu-nav-link dropdown-menu-nav-link-no_margin', title: 'Newest Digital Scrapbooking Art and Embellishments' %>
              </li>

              <li>
                <%= link_to 'Free Kits', free_digital_art_url, class: 'dropdown-menu-nav-link dropdown-menu-nav-link-no_margin', title: 'On Sale Digital Scrapbooking Art and Embellishments' %>
              </li>

              <li>
                <%= link_to 'Browse All', all_digital_art_url, class: 'dropdown-menu-nav-link dropdown-menu-nav-link-no_margin', title: 'All Digital Scrapbooking Art and Embellishments' %>
              </li>
            </ul>
          </li>

          <li>
            <%= link_to trademark('pixels2Pages'), p2p_url, class: 'dropdown-menu-nav-link', title: 'Premium Training and Resources' %>
            <small class="dropdown-menu-nav-link-subhead">Premium Training and Resources</small>
          </li>

        </ul>
      </div>

      <div class='col-grid-float-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title page-title color-primary'>Account Services</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to storage_url, class: 'dropdown-menu-nav-link', title: 'Guaranteed Permanent Storage for Photos & Documents' do %>
              <%= trademark("Forever Storage") %>
            <% end %>
            <small class="dropdown-menu-nav-link-subhead">Permanent cloud storage</small>
          </li>

          <li>
            <%= link_to services_url, class: 'dropdown-menu-nav-link', title: 'Digitization and Scanning Services' do %>
              Photo Scanning <br/>and Video Conversion
            <% end %>
          </li>

          <li>
            <%= link_to trademark('Forever Valet'), valet_url, class: 'dropdown-menu-nav-link', title: 'Forever Valet Desktop Photo Uploader'  %>
            <small class="dropdown-menu-nav-link-subhead">Desktop Uploader</small>
          </li>
        </ul>
      </div>


      <div class='col-grid-float-3 l-padded-thin'>
        <h3 class='dropdown-menu-nav-title color-primary-light'>Mobile Apps</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to 'Forever™ Mobile Apps', app_url, class: 'dropdown-menu-nav-link', title: 'Download Forever Mobile Apps' %>
          </li>

          <li>
            <%= link_to 'Download the iPhone App', ios_url, class: 'dropdown-menu-nav-link', title: 'Download Forever Mobile Apps' %>
          </li>


          <li>
            <%= link_to 'Download the Android App', android_url, class: 'dropdown-menu-nav-link', title: 'Download Forever Mobile Apps' %>
          </li>
        </ul>


        <h3 class='dropdown-menu-nav-title color-ambassador-light l-section'>Gifts</h3>

        <ul class="list-unstyled">
          <li>
            <%= link_to 'Gift Certificates', gifts_url, class: 'dropdown-menu-nav-link', title: 'Buy Forever Gift Certificates' %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
